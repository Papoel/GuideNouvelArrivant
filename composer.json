{
    "type": "project",
    "name": "papoel/compagnonnage",
    "description": "Carnet de compagnonnage d'un nouvel arrivant",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.4.3",
        "doctrine/doctrine-bundle": "^3.2.2",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6.4",
        "dompdf/dompdf": "^3.1.5",
        "dragonmantank/cron-expression": "^3.4",
        "easycorp/easyadmin-bundle": "^5.0.7",
        "php-flasher/flasher-sweetalert-symfony": "^2.1",
        "php-flasher/flasher-symfony": "^2.1",
        "phpdocumentor/reflection-docblock": "^6.0.3",
        "phpstan/phpdoc-parser": "^2.3.2",
        "symfony/asset": "8.0.*",
        "symfony/asset-mapper": "8.0.*",
        "symfony/console": "8.0.*",
        "symfony/doctrine-messenger": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/expression-language": "8.0.*",
        "symfony/flex": "^2.10",
        "symfony/form": "8.0.*",
        "symfony/framework-bundle": "8.0.*",
        "symfony/http-client": "8.0.*",
        "symfony/intl": "8.0.*",
        "symfony/mailer": "8.0.*",
        "symfony/mime": "8.0.*",
        "symfony/monolog-bundle": "^3.0|^4.0.2",
        "symfony/notifier": "8.0.*",
        "symfony/process": "8.0.*",
        "symfony/property-access": "8.0.*",
        "symfony/property-info": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/scheduler": "8.0.*",
        "symfony/security-bundle": "8.0.*",
        "symfony/serializer": "8.0.*",
        "symfony/stimulus-bundle": "^3.0",
        "symfony/string": "8.0.*",
        "symfony/translation": "8.0.*",
        "symfony/twig-bundle": "8.0.*",
        "symfony/uid": "8.0.*",
        "symfony/ux-icons": "^3.0",
        "symfony/ux-live-component": "^3.0",
        "symfony/ux-turbo": "^3.0",
        "symfony/ux-twig-component": "^3.0",
        "symfony/validator": "8.0.*",
        "symfony/web-link": "8.0.*",
        "symfony/yaml": "8.0.*",
        "symfonycasts/reset-password-bundle": "^1.23",
        "symfonycasts/verify-email-bundle": "^1.17",
        "twig/cssinliner-extra": "^3.24",
        "twig/extra-bundle": "^3.24",
        "twig/twig": "^2.12|^3.24",
        "twig/inky-extra": "^3",
        "twig/intl-extra": "^3.21"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true,
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "before-commit": [
            "make before-commit"
        ],
        "db-reset": [
            "php bin/console doctrine:database:drop --force --if-exists",
            "php bin/console doctrine:database:create",
            "php bin/console doctrine:migrations:migrate --no-interaction",
            "php bin/console doctrine:fixtures:load --group=AppFixtures --no-interaction"
        ],
        "qa:cs-fixer": "docker run --init --rm -v $(pwd):/project -w /project jakzal/phpqa:php8.3 php-cs-fixer fix ./src --rules=@Symfony --verbose --dry-run",
        "qa:phpstan": "docker run --init --rm -v $(pwd):/project -w /project jakzal/phpqa:php8.3 phpstan analyse --configuration=phpstan.neon",
        "qa:phpcpd": "docker run --init --rm -v $(pwd):/project -w /project jakzal/phpqa:php8.3 phpcpd ./src",
        "qa:lint-yaml": "php bin/console lint:yaml config",
        "qa:lint-twig": "php bin/console lint:twig templates",
        "qa:lint-container": "php bin/console lint:container",
        "app:tests": "vendor/bin/phpunit",
        "app:code-quality": [
            "@qa:cs-fixer",
            "@qa:phpstan",
            "@qa:phpcpd",
            "@qa:lint-yaml",
            "@qa:lint-twig",
            "@qa:lint-container"
        ],
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    },
    "require-dev": {
        "doctrine/doctrine-fixtures-bundle": "^4.3.1",
        "fakerphp/faker": "^1.24",
        "phpunit/phpunit": "^13.1.8",
        "rector/rector": "^2.4",
        "roave/security-advisories": "dev-latest",
        "symfony/browser-kit": "8.0.*",
        "symfony/css-selector": "8.0.*",
        "symfony/debug-bundle": "8.0.*",
        "symfony/maker-bundle": "^1.67",
        "symfony/phpunit-bridge": "^8.0.8",
        "symfony/stopwatch": "8.0.*",
        "symfony/web-profiler-bundle": "8.0.*"
    }
}
