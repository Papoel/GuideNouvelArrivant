<!-- ======= Sidebar ======= -->
<aside id="sidebar" class="sidebar">
    <div class="sidebar-header">
        <a href="{{ path('dashboard_index', {'nni': app.user.nni}) }}" class="sidebar-brand">
            <div class="brand-icon">
                <i class="bi bi-speedometer2"></i>
            </div>
            <div class="brand-text">
                <h4 class="brand-title">Tableau de bord</h4>
                <p class="brand-subtitle">Vue d'ensemble</p>
            </div>
        </a>
    </div>

    <div class="sidebar-content">
        <nav class="sidebar-nav">
            <a href="{{ path('pages_guide_technique') }}" class="nav-item">
                <div class="nav-icon">
                    <i class="bi bi-bookmark-check"></i>
                </div>
                <span class="nav-label">Guide Technique</span>
            </a>
        </nav>


        {% if app.user.logbooks is defined and app.user.logbooks is not empty %}
            {% set logbooksProgress = get_logbooks_progress(app.user.logbooks) %}
            {% for logbookProgress in logbooksProgress %}
                <div class="progress-card">
                    <div class="progress-header">
                        <div class="progress-icon">
                            <i class="bi bi-journal-check"></i>
                        </div>
                        <h5 class="progress-title">Votre Progression</h5>
                    </div>

                    <div class="progress-section">
                        <div class="progress-item">
                            <div class="progress-label-wrapper">
                                <span class="progress-label">Progression de l'agent</span>
                                <span class="progress-badge {{ logbookProgress.progress_class_agent }}">{{ logbookProgress.agent_progress }}%</span>
                            </div>
                            <div class="progress-stats">
                                <span class="stats-text">{{ logbookProgress.completed_by_agent }} / {{ logbookProgress.total_modules }} modules complétés</span>
                            </div>
                        </div>

                        <div class="progress-divider"></div>

                        <div class="progress-item">
                            <div class="progress-label-wrapper">
                                <span class="progress-label">Validation du tuteur</span>
                            </div>
                            <div class="progress-stats">
                                <span class="stats-text">{{ logbookProgress.validated_by_mentor }} / {{ logbookProgress.total_modules }} modules validés</span>
                            </div>
                        </div>

                        {% if logbookProgress.modules_awaiting_validation > 0 %}
                            <div class="progress-alert alert-warning">
                                <i class="bi bi-clock-history"></i>
                                <span>{{ logbookProgress.modules_awaiting_validation }} en attente de validation</span>
                            </div>
                        {% else %}
                            <div class="progress-alert alert-success">
                                <i class="bi bi-check-circle"></i>
                                <span>Aucun module en attente</span>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        {% else %}
            <div class="empty-state">
                <div class="empty-icon">
                    <i class="bi bi-info-circle"></i>
                </div>
                <p class="empty-text">Aucun carnet de progression disponible.</p>
            </div>
        {% endif %}
        {# TODO: P1: Lorsque je désigne un tuteur je dois lui affecter le ROLE_MENTOR avec un listener #}
        {% if is_granted('ROLE_MENTOR') %}
            <div class="mentor-section">
                <div class="section-header">
                    <h5 class="section-title">Actions Tuteurs</h5>
                </div>
                <div class="mentor-card">
                    <a class="mentor-toggle" data-bs-toggle="collapse" href="#aside-crud" role="button"
                       aria-expanded="false" aria-controls="aside-crud">
                        <div class="toggle-icon">
                            <i class="bi bi-file-ruled"></i>
                        </div>
                        <span class="toggle-label">Tutorat</span>
                        <i class="bi bi-chevron-down toggle-chevron"></i>
                    </a>
                    <div class="collapse" id="aside-crud">
                        <div class="mentor-links">
                            <a href="{{ path('mentor_dashboard_index', {'nni': app.user.nni}) }}" class="mentor-link">
                                <i class="bi bi-arrow-right-short"></i>
                                <span>Carnets des Collaborateurs</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</aside>
<!-- End Sidebar-->

<!-- Modal Feedback -->
<div class="modal fade" id="feedbackModal" tabindex="-1" aria-labelledby="feedbackModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title" id="feedbackModalLabel">Partagez votre retour d'expérience</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                {% if feedback_form is defined %}
                    {{ form_start(feedback_form) }}
                    <div class="mb-3">
                        {{ form_label(feedback_form.title) }}
                        {{ form_widget(feedback_form.title) }}
                        {{ form_errors(feedback_form.title) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(feedback_form.category) }}
                        {{ form_widget(feedback_form.category) }}
                        {{ form_errors(feedback_form.category) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(feedback_form.content) }}
                        {{ form_widget(feedback_form.content) }}
                        {{ form_errors(feedback_form.content) }}
                    </div>
                    <div class="d-flex justify-content-end">
                        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal">Annuler</button>
                        <button type="submit" class="btn btn-primary">Envoyer</button>
                    </div>
                    {{ form_end(feedback_form) }}
                {% else %}
                    <div class="alert alert-warning">Le formulaire n'est pas disponible.</div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
