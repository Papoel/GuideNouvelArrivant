<footer id="footer" class="footer">
    <div class="footer-container">
        <div class="footer-content">
            <!-- Main Footer Row -->
            <div class="footer-main">
                <div class="footer-brand">
                    <div class="brand-logo">
                        <i class="bi bi-building"></i>
                    </div>
                    <div class="brand-info">
                        <h4 class="brand-name">Guide du Nouvel Arrivant</h4>
                        <p class="brand-tagline">Accompagnement dans le parcours d'intégration EDF.</p>
                    </div>
                </div>
                
                <div class="footer-meta">
                    <div class="meta-item update-info">
                        <div class="meta-icon">
                            <i class="bi bi-arrow-clockwise"></i>
                        </div>
                        <div class="meta-content">
                            <span class="meta-label">Mise à jour</span>
                            <span class="meta-value">
                                {% set lastUpdate = git_last_commit_date() %}
                                {% if lastUpdate %}
                                    {{ lastUpdate|date('d/m/Y', "Europe/Paris") }}
                                {% else %}
                                    {{ "now"|date('d/m/Y', "Europe/Paris") }}
                                {% endif %}
                            </span>
                        </div>
                    </div>
                </div>
                
                <div class="footer-links">
                    <a href="{{ path('app_privacy_policy') }}" class="footer-link">
                        <span>Confidentialité</span>
                    </a>
                    <span class="link-divider"></span>
                    <a href="{{ path('app_legal_notices') }}" class="footer-link">
                        <span>Mentions légales</span>
                    </a>
                </div>
            </div>
            
            <!-- Footer Bottom -->
            <div class="footer-bottom">
                <div class="footer-copyright">
                    <span>&copy; {{ "now"|date("Y") }} Pascal Briffard</span>
                    <span class="separator">·</span>
                    <span>Tous droits réservés</span>
                </div>
                
                <div class="footer-tech">
                    <span class="tech-text">Propulsé par</span>
                    <a href="https://symfony.com" target="_blank" class="tech-badge">
                        <i class="bi bi-lightning-charge-fill"></i>
                        <span>Symfony</span>
                    </a>
                    <a href="https://getbootstrap.com" target="_blank" class="tech-badge">
                        <i class="bi bi-bootstrap-fill"></i>
                        <span>Bootstrap</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</footer>
