{% extends 'base.html.twig' %}

{% block title %}Détail du retour d'expérience - Administration{% endblock %}

{% block body %}
<div class="container-fluid px-3 px-lg-4 py-4">
	{# En-tête de page #}
	<div class="page-header mb-4">
		<div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3">
			<div>
				<h1 class="page-title mb-2">
					<twig:ux:icon name="bi:chat-dots" class="me-2"/>
					Détail du retour d'expérience
				</h1>
				<p class="page-subtitle mb-0">Consultez et traitez ce retour d'expérience</p>
			</div>
			<a href="{{ path('admin_progress_feedbacks') }}" class="btn btn-outline-secondary">
				<twig:ux:icon name="bi:arrow-left" class="me-2"/>
				Retour à la liste
			</a>
		</div>
	</div>

	{# Carte principale #}
	<div class="feedback-detail-card">
		{# En-tête avec titre et statut #}
		<div class="feedback-header">
			<h2 class="feedback-title">{{ feedback.title }}</h2>
			{% if feedback.isReviewed %}
				<span class="status-badge status-badge-success">
					<twig:ux:icon name="bi:check-circle" class="me-1"/>
					Traité
				</span>
			{% else %}
				<span class="status-badge status-badge-warning">
					<twig:ux:icon name="bi:clock" class="me-1"/>
					En attente
				</span>
			{% endif %}
		</div>

		{# Informations auteur et métadonnées #}
		<div class="feedback-meta">
			<div class="row g-3 g-lg-4">
				<div class="col-12 col-lg-6">
					<div class="author-info">
						<div class="author-avatar">
							{{ feedback.author.firstname|first }}{{ feedback.author.lastname|first }}
						</div>
						<div class="author-details">
							<div class="author-name">{{ feedback.author.firstname }} {{ feedback.author.lastname }}</div>
							<div class="author-email">
								<twig:ux:icon name="bi:envelope" class="me-1"/>
								{{ feedback.author.email }}
							</div>
						</div>
					</div>
				</div>
				<div class="col-12 col-lg-6">
					<div class="feedback-metadata">
						<div class="metadata-item">
							<div class="metadata-label">
								<twig:ux:icon name="bi:calendar-check" class="me-1"/>
								Soumis le
							</div>
							<div class="metadata-value">{{ feedback.createdAt|date('d/m/Y à H:i') }}</div>
						</div>
						<div class="metadata-item">
							<div class="metadata-label">
								<twig:ux:icon name="bi:tag" class="me-1"/>
								Catégorie
							</div>
							<div class="metadata-value">
								{% set category_config = {
									'integration_process': {label: 'Processus d\'intégration', color: 'primary'},
									'training': {label: 'Formation', color: 'success'},
									'documentation': {label: 'Documentation', color: 'info'},
									'tools': {label: 'Outils', color: 'warning'},
									'communication': {label: 'Communication', color: 'secondary'},
									'other': {label: 'Autre', color: 'dark'}
								} %}
								<span class="category-badge category-badge-{{ category_config[feedback.category].color }}">
									{{ category_config[feedback.category].label }}
								</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		{# Contenu du retour #}
		<div class="feedback-content-section">
			<div class="section-header">
				<twig:ux:icon name="bi:chat-quote" class="me-2"/>
				Contenu du retour
			</div>
			<div class="section-content">
				{{ feedback.content|nl2br }}
			</div>
		</div>

		{# Réponse du manager ou formulaire #}
		{% if feedback.isReviewed %}
			<div class="manager-response-section">
				<div class="response-header">
					<div class="response-title">
						<twig:ux:icon name="bi:reply" class="me-2"/>
						Réponse du manager
					</div>
					<div class="response-meta">
						<twig:ux:icon name="bi:person-check" class="me-1"/>
						Traité le {{ feedback.reviewAt|date('d/m/Y') }} par {{ feedback.reviewedBy.firstname }} {{ feedback.reviewedBy.lastname }}
					</div>
				</div>
				<div class="response-content">
					{{ feedback.managerComment|nl2br }}
				</div>
				<div class="response-actions">
					<form method="post" action="{{ path('admin_progress_feedback_detail', {'id': feedback.id}) }}">
						<input type="hidden" name="action" value="mark_pending">
						<button type="submit" class="btn btn-outline-warning">
							<twig:ux:icon name="bi:arrow-clockwise" class="me-2"/>
							Remettre en attente
						</button>
					</form>
				</div>
			</div>
		{% else %}
			<div class="manager-form-section">
				<div class="form-header">
					<twig:ux:icon name="bi:reply" class="me-2"/>
					Traiter ce retour d'expérience
				</div>
				<form method="post" action="{{ path('admin_progress_feedback_detail', {'id': feedback.id}) }}">
					<input type="hidden" name="action" value="mark_reviewed">
					<div class="form-group">
						<label for="managerComment" class="form-label">Votre commentaire</label>
						<textarea
							class="form-control"
							id="managerComment"
							name="managerComment"
							rows="6"
							placeholder="Rédigez votre réponse..."
							aria-describedby="commentHelp"
						></textarea>
						<div id="commentHelp" class="form-help">
							<twig:ux:icon name="bi:info-circle" class="me-1"/>
							Votre commentaire sera visible par l'auteur du retour d'expérience.
						</div>
					</div>
					<div class="form-actions">
						<button type="submit" class="btn btn-primary">
							<twig:ux:icon name="bi:check-circle" class="me-2"/>
							Marquer comme traité
						</button>
					</div>
				</form>
			</div>
		{% endif %}
	</div>
</div>

<style>
	:root {
		--primary-color: #3d5f9e;
		--primary-light: rgba(61, 95, 158, 0.08);
		--success-color: #28a745;
		--success-light: rgba(40, 167, 69, 0.08);
		--warning-color: #ffc107;
		--warning-light: rgba(255, 193, 7, 0.08);
		--info-color: #17a2b8;
		--info-light: rgba(23, 162, 184, 0.08);
		--secondary-color: #6c757d;
		--secondary-light: rgba(108, 117, 125, 0.08);
		--dark-color: #2c384e;
		--dark-light: rgba(44, 56, 78, 0.08);
		--text-dark: #2c384e;
		--text-muted: #6c757d;
		--border-color: #e9ecef;
		--bg-light: #f8f9fa;
		--card-radius: 0.75rem;
		--transition: all 0.2s ease;
	}

	/* En-tête de page */
	.page-header {
		margin-bottom: 2rem;
	}

	.page-title {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--text-dark);
		display: flex;
		align-items: center;
		margin: 0;
	}

	.page-subtitle {
		font-size: 0.95rem;
		color: var(--text-muted);
	}

	/* Carte de détail du feedback */
	.feedback-detail-card {
		background: white;
		border-radius: var(--card-radius);
		border: 1px solid var(--border-color);
		overflow: hidden;
	}

	/* En-tête du feedback */
	.feedback-header {
		padding: 1.5rem;
		border-bottom: 1px solid var(--border-color);
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.feedback-title {
		font-size: 1.25rem;
		font-weight: 600;
		color: var(--text-dark);
		margin: 0;
		flex: 1;
	}

	/* Métadonnées du feedback */
	.feedback-meta {
		padding: 1.5rem;
		border-bottom: 1px solid var(--border-color);
		background: var(--bg-light);
	}

	/* Informations auteur */
	.author-info {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.author-avatar {
		width: 3.5rem;
		height: 3.5rem;
		border-radius: 50%;
		background: var(--primary-color);
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.25rem;
		font-weight: 600;
		flex-shrink: 0;
	}

	.author-details {
		flex: 1;
	}

	.author-name {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-dark);
		margin-bottom: 0.25rem;
	}

	.author-email {
		font-size: 0.875rem;
		color: var(--text-muted);
		display: flex;
		align-items: center;
	}

	/* Métadonnées */
	.feedback-metadata {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		justify-content: flex-start;
	}

	.metadata-item {
		flex: 1;
		min-width: 200px;
	}

	.metadata-label {
		font-size: 0.875rem;
		color: var(--text-muted);
		margin-bottom: 0.5rem;
		display: flex;
		align-items: center;
	}

	.metadata-value {
		font-weight: 500;
		color: var(--text-dark);
	}

	/* Badges */
	.category-badge {
		display: inline-block;
		padding: 0.375rem 0.75rem;
		border-radius: 2rem;
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.category-badge-primary {
		background: var(--primary-light);
		color: var(--primary-color);
	}

	.category-badge-success {
		background: var(--success-light);
		color: var(--success-color);
	}

	.category-badge-info {
		background: var(--info-light);
		color: var(--info-color);
	}

	.category-badge-warning {
		background: var(--warning-light);
		color: var(--warning-color);
	}

	.category-badge-secondary {
		background: var(--secondary-light);
		color: var(--secondary-color);
	}

	.category-badge-dark {
		background: var(--dark-light);
		color: var(--dark-color);
	}

	.status-badge {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 1rem;
		border-radius: 2rem;
		font-size: 0.875rem;
		font-weight: 600;
		white-space: nowrap;
	}

	.status-badge-success {
		background: var(--success-light);
		color: var(--success-color);
	}

	.status-badge-warning {
		background: var(--warning-light);
		color: var(--warning-color);
	}

	/* Section contenu du feedback */
	.feedback-content-section {
		padding: 1.5rem;
		border-bottom: 1px solid var(--border-color);
	}

	.section-header {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-dark);
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
	}

	.section-content {
		background: var(--bg-light);
		border: 1px solid var(--border-color);
		border-radius: 0.5rem;
		padding: 1.25rem;
		line-height: 1.7;
		color: var(--text-dark);
		font-size: 0.95rem;
	}

	/* Section réponse du manager */
	.manager-response-section {
		padding: 1.5rem;
	}

	.response-header {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.response-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-dark);
		display: flex;
		align-items: center;
	}

	.response-meta {
		font-size: 0.875rem;
		color: var(--text-muted);
		display: flex;
		align-items: center;
	}

	.response-content {
		background: white;
		border: 1px solid var(--border-color);
		border-radius: 0.5rem;
		padding: 1.25rem;
		line-height: 1.7;
		color: var(--text-dark);
		font-size: 0.95rem;
		margin-bottom: 1.5rem;
	}

	.response-actions {
		display: flex;
		justify-content: flex-end;
	}

	/* Section formulaire */
	.manager-form-section {
		padding: 1.5rem;
	}

	.form-header {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-dark);
		margin-bottom: 1.5rem;
		display: flex;
		align-items: center;
	}

	.form-group {
		margin-bottom: 1.5rem;
	}

	.form-label {
		display: block;
		font-weight: 500;
		color: var(--text-dark);
		margin-bottom: 0.5rem;
		font-size: 0.95rem;
	}

	.form-control {
		width: 100%;
		padding: 0.75rem;
		border: 1px solid var(--border-color);
		border-radius: 0.5rem;
		font-size: 0.95rem;
		color: var(--text-dark);
		transition: var(--transition);
		line-height: 1.6;
	}

	.form-control:focus {
		outline: none;
		border-color: var(--primary-color);
		box-shadow: 0 0 0 3px var(--primary-light);
	}

	.form-control::placeholder {
		color: var(--text-muted);
	}

	.form-help {
		margin-top: 0.5rem;
		font-size: 0.875rem;
		color: var(--text-muted);
		display: flex;
		align-items: center;
	}

	.form-actions {
		display: flex;
		justify-content: flex-end;
	}

	/* Boutons */
	.btn {
		display: inline-flex;
		align-items: center;
		padding: 0.75rem 1.5rem;
		border-radius: 2rem;
		font-size: 0.95rem;
		font-weight: 500;
		text-decoration: none;
		border: 1px solid transparent;
		cursor: pointer;
		transition: var(--transition);
		white-space: nowrap;
	}

	.btn-primary {
		background: var(--primary-color);
		color: white;
		border-color: var(--primary-color);
	}

	.btn-primary:hover {
		background: #2d4a7c;
		border-color: #2d4a7c;
		transform: translateY(-1px);
		box-shadow: 0 4px 12px rgba(61, 95, 158, 0.2);
	}

	.btn-outline-secondary {
		background: white;
		color: var(--text-dark);
		border-color: var(--border-color);
	}

	.btn-outline-secondary:hover {
		background: var(--bg-light);
		border-color: var(--text-muted);
	}

	.btn-outline-warning {
		background: white;
		color: var(--warning-color);
		border-color: var(--warning-color);
	}

	.btn-outline-warning:hover {
		background: var(--warning-color);
		color: white;
		transform: translateY(-1px);
		box-shadow: 0 4px 12px rgba(255, 193, 7, 0.2);
	}

	/* Responsive */
	@media (max-width: 991.98px) {
		.page-title {
			font-size: 1.5rem;
		}

		.feedback-title {
			font-size: 1.125rem;
		}

		.feedback-metadata {
			flex-direction: column;
			gap: 1rem;
		}

		.metadata-item {
			min-width: 0;
		}

		.response-header {
			flex-direction: column;
			align-items: flex-start;
		}
	}

	@media (max-width: 575.98px) {
		.page-title {
			font-size: 1.25rem;
		}

		.feedback-header,
		.feedback-meta,
		.feedback-content-section,
		.manager-response-section,
		.manager-form-section {
			padding: 1.25rem;
		}

		.author-avatar {
			width: 3rem;
			height: 3rem;
			font-size: 1.125rem;
		}

		.feedback-header {
			flex-direction: column;
			align-items: flex-start;
		}
	}

	/* Accessibilité */
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		* {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
		}
	}
</style>
{% endblock %}
