{% extends 'base.html.twig' %}

{% block title %}Détails de progression - {{ user.fullName }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/manager/manager_view.css') }}">
{% endblock %}

{% block body %}
<div class="dash-container">
    {# === HEADER === #}
    <div class="dash-header">
        <div class="dash-header-title">
            <div class="dash-header-icon">
                <i class="bi bi-person-badge"></i>
            </div>
            <div>
                <h1>{{ user.fullName }}</h1>
                <p class="dash-header-subtitle">Tableau de bord de progression des modules</p>
            </div>
        </div>
        <a href="{{ path('admin_progress_dashboard') }}" class="dash-btn-back">
            <i class="bi bi-arrow-left"></i>
            Retour au tableau
        </a>
    </div>

    {# === METRICS === #}
    <div class="dash-metrics">
        <div class="dash-metric-card">
            <div class="dash-metric-header">
                <span class="dash-metric-label">Progression de l'agent</span>
                <div class="dash-metric-icon">
                    <i class="bi bi-person-check"></i>
                </div>
            </div>
            <div class="dash-metric-value">{{ progress.agent_progress }}%</div>
            <div class="dash-metric-detail">{{ progress.completed_by_agent }} modules validés</div>
        </div>
        
        <div class="dash-metric-card">
            <div class="dash-metric-header">
                <span class="dash-metric-label">Validation tuteur</span>
                <div class="dash-metric-icon">
                    <i class="bi bi-award"></i>
                </div>
            </div>
            <div class="dash-metric-value">{{ progress.mentor_progress }}%</div>
            <div class="dash-metric-detail">{{ progress.validated_by_mentor }} modules validés</div>
        </div>
        
        <div class="dash-metric-card">
            <div class="dash-metric-header">
                <span class="dash-metric-label">Total modules</span>
                <div class="dash-metric-icon">
                    <i class="bi bi-list-check"></i>
                </div>
            </div>
            <div class="dash-metric-value">{{ progress.total_modules }}</div>
            <div class="dash-metric-detail">{{ logbook.name }}</div>
        </div>
    </div>

    {# === INFO GRID === #}
    <div class="dash-info-grid">
        <div class="dash-info-card">
            <h2 class="dash-info-title">Informations générales</h2>
            <div class="dash-info-row">
                <span class="dash-info-key">Email</span>
                <span class="dash-info-value">{{ user.email }}</span>
            </div>
            <div class="dash-info-row">
                <span class="dash-info-key">NNI</span>
                <span class="dash-info-value">{{ user.nni }}</span>
            </div>
            <div class="dash-info-row">
                <span class="dash-info-key">Date embauche</span>
                <span class="dash-info-value">
                    {% if user.hiringAt %}
                        {{ user.hiringAt|date('d/m/Y') }}
                    {% else %}
                        <span class="text-muted">Non renseigné</span>
                    {% endif %}
                </span>
            </div>
        </div>

        <div class="dash-info-card">
            <h2 class="dash-info-title">Affectation tutorat</h2>
            <div class="dash-info-row">
                <span class="dash-info-key">Tuteur</span>
                <span class="dash-info-value">
                    {% if user.mentor %}
                        {{ user.mentor.fullName }}
                    {% else %}
                        <span class="dash-badge dash-badge-warning">Non assigné</span>
                    {% endif %}
                </span>
            </div>
            <div class="dash-info-row">
                <span class="dash-info-key">Poste</span>
                <span class="dash-info-value">
                    {% if user.job %}
                        {{ user.job.name }}
                    {% else %}
                        <span class="text-muted">Non renseigné</span>
                    {% endif %}
                </span>
            </div>
            <div class="dash-info-row">
                <span class="dash-info-key">Spécialité</span>
                <span class="dash-info-value">
                    {% if user.speciality %}
                        {{ user.speciality.name }}
                    {% else %}
                        <span class="text-muted">Non renseigné</span>
                    {% endif %}
                </span>
            </div>
        </div>
    </div>

    {# === TABLE DESKTOP === #}
    <div class="dash-table-section">
        <div class="dash-table-header">
            <h2 class="dash-table-title">
                <i class="bi bi-book"></i>
                Détail des modules
            </h2>
            <div>
                <span class="dash-badge dash-badge-primary">{{ logbook.themes|length }} thèmes</span>
            </div>
        </div>

        <div class="dash-table-wrapper d-none d-lg-block">
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Thème</th>
                        <th>Module</th>
                        <th>Validation agents</th>
                        <th>Validation tuteur</th>
                        <th>Commentaire</th>
                    </tr>
                </thead>
                <tbody>
                    {% for theme in logbook.themes %}
                        {% set first = true %}
                        {% for module in theme.modules %}
                            {% set action = null %}
                            {% for a in user.actions %}
                                {% if a.module.id == module.id %}
                                    {% set action = a %}
                                {% endif %}
                            {% endfor %}
                            <tr>
                                {% if first %}
                                    <td rowspan="{{ theme.modules|length }}">{{ theme.title }}</td>
                                    {% set first = false %}
                                {% endif %}
                                <td>{{ module.title }}</td>
                                <td>
                                    {% if action and action.agentValidatedAt %}
                                        <span class="dash-badge dash-badge-success">
                                            <i class="bi bi-check-circle"></i>
                                            {{ action.agentValidatedAt|date('d/m/Y') }}
                                        </span>
                                    {% else %}
                                        <span class="dash-badge dash-badge-secondary">Non validé</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if action and action.mentorValidatedAt %}
                                        <span class="dash-badge dash-badge-success">
                                            <i class="bi bi-check-circle"></i>
                                            {{ action.mentorValidatedAt|date('d/m/Y') }}
                                        </span>
                                        <form method="post" id="form_mentor_{{ action.id|replace({'-': '_'}) }}" action="{{ path('admin_progress_invalidate_action', {userId: user.id, actionId: action.id}) }}" class="d-inline">
                                            <input type="hidden" name="validation_type" value="mentor">
                                            <button type="button" class="dash-btn dash-btn-danger" data-bs-toggle="modal" data-bs-target="#modal_mentor_{{ action.id|replace({'-': '_'}) }}">
                                                <i class="bi bi-x-circle"></i>Dévalider
                                            </button>
                                        </form>
                                    {% else %}
                                        <span class="dash-badge dash-badge-secondary">Non validé</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if action and (action.agentComment or action.mentorComment) %}
                                        <div popover id="popover_{{ module.id }}">
                                            <div class="dash-popover-header">
                                                <h3 class="dash-popover-title">Commentaires</h3>
                                                <button class="dash-popover-close" popovertarget="popover_{{ module.id }}">×</button>
                                            </div>
                                            <div class="dash-popover-body">
                                                {% if action.agentComment %}
                                                    <strong>{{ user.firstName }} :</strong>
                                                    <p class="mt-1 mb-3">{{ action.agentComment }}</p>
                                                {% endif %}
                                                {% if action.mentorComment %}
                                                    <strong>{% if user.mentor %}{{ user.mentor.firstName }}{% else %}Tuteur{% endif %} :</strong>
                                                    <p class="mt-1">{{ action.mentorComment }}</p>
                                                {% endif %}
                                            </div>
                                        </div>
                                        <button class="dash-btn dash-btn-comment" popovertarget="popover_{{ module.id }}">
                                            <i class="bi bi-chat-text"></i>Voir
                                        </button>
                                    {% else %}
                                        <button class="dash-btn dash-btn-comment" disabled>
                                            <i class="bi bi-chat-text"></i>Aucun
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# Mobile view #}
        <div class="d-block d-lg-none">
            {% for theme in logbook.themes %}
                <div class="dash-mobile-theme">
                    <h6>
                        <i class="bi bi-bookmark"></i>
                        {{ theme.title }}
                    </h6>
                </div>
                <div class="dash-mobile-module">
                    {% for module in theme.modules %}
                        {% set action = null %}
                        {% for a in user.actions %}
                            {% if a.module.id == module.id %}
                                {% set action = a %}
                            {% endif %}
                        {% endfor %}
                        
                        <h6 class="dash-mobile-module-title">{{ module.title }}</h6>
                        
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <strong class="d-block mb-2 small">Auto-validation</strong>
                                {% if action and action.agentValidatedAt %}
                                    <span class="dash-badge dash-badge-success d-block mb-2">
                                        {{ action.agentValidatedAt|date('d/m/Y') }}
                                    </span>
                                {% else %}
                                    <span class="dash-badge dash-badge-secondary">Non validé</span>
                                {% endif %}
                            </div>
                            <div class="col-6">
                                <strong class="d-block mb-2 small">Validation tuteur</strong>
                                {% if action and action.mentorValidatedAt %}
                                    <span class="dash-badge dash-badge-success d-block mb-2">
                                        {{ action.mentorValidatedAt|date('d/m/Y') }}
                                    </span>
                                    <form method="post" id="form_mentor_mobile_{{ action.id|replace({'-': '_'}) }}" action="{{ path('admin_progress_invalidate_action', {userId: user.id, actionId: action.id}) }}" class="d-inline">
                                        <input type="hidden" name="validation_type" value="mentor">
                                        <button type="button" class="dash-btn dash-btn-danger" data-bs-toggle="modal" data-bs-target="#modal_mentor_mobile_{{ action.id|replace({'-': '_'}) }}">
                                            <i class="bi bi-x-circle"></i>Dévalider
                                        </button>
                                    </form>
                                {% else %}
                                    <span class="dash-badge dash-badge-secondary">Non validé</span>
                                {% endif %}
                            </div>
                        </div>
                        
                        {% if action and (action.agentComment or action.mentorComment) %}
                            <div class="accordion">
                                <div class="accordion-item">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#comments_{{ module.id }}">
                                            <i class="bi bi-chat-text me-2"></i>Commentaires
                                        </button>
                                    </h2>
                                    <div id="comments_{{ module.id }}" class="accordion-collapse collapse">
                                        <div class="accordion-body small">
                                            {% if action.agentComment %}
                                                <strong>{{ user.firstName }} :</strong>
                                                <p>{{ action.agentComment }}</p>
                                            {% endif %}
                                            {% if action.mentorComment %}
                                                <strong>{% if user.mentor %}{{ user.mentor.firstName }}{% else %}Tuteur{% endif %} :</strong>
                                                <p>{{ action.mentorComment }}</p>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                        
                        {% if not loop.last %}
                            <hr class="my-4">
                        {% endif %}
                    {% endfor %}
                </div>
            {% endfor %}
        </div>
    </div>
</div>

{# === MODALS === #}
{% for theme in logbook.themes %}
    {% for module in theme.modules %}
        {% set action = null %}
        {% for a in user.actions %}
            {% if a.module.id == module.id %}
                {% set action = a %}
            {% endif %}
        {% endfor %}
        
        {# Modal mentor desktop #}
        {% if action and action.mentorValidatedAt %}
            <div class="modal fade" id="modal_mentor_{{ action.id|replace({'-': '_'}) }}" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content dash-modal-confirm">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="bi bi-exclamation-triangle"></i>
                                Confirmation de dévalidation
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center">
                            <div class="dash-modal-icon">
                                <i class="bi bi-x-octagon"></i>
                            </div>
                            <h6 class="dash-modal-heading">Supprimer la validation tuteur</h6>
                            <div class="dash-modal-module">{{ module.title }}</div>
                            <div class="dash-modal-date">
                                <i class="bi bi-calendar-check"></i> Validé le {{ action.mentorValidatedAt|date('d/m/Y') }}
                            </div>
                            <div class="dash-modal-warning">
                                <p><strong>Attention :</strong> Cette action supprimera la validation du tuteur pour ce module.</p>
                                <p class="mb-0 small">Le tuteur devra revalider lors du prochain échange.</p>
                            </div>
                            <p class="dash-modal-confirm-text">Confirmer la suppression ?</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="dash-modal-btn-cancel" data-bs-dismiss="modal">Annuler</button>
                            <button type="button" class="dash-modal-btn-confirm" onclick="document.getElementById('form_mentor_{{ action.id|replace({'-': '_'}) }}').submit();">Confirmer</button>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
        
        {# Modal mentor mobile #}
        {% if action and action.mentorValidatedAt %}
            <div class="modal fade" id="modal_mentor_mobile_{{ action.id|replace({'-': '_'}) }}" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content dash-modal-confirm">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="bi bi-exclamation-triangle"></i>
                                Confirmation
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body text-center">
                            <div class="dash-modal-icon">
                                <i class="bi bi-x-octagon"></i>
                            </div>
                            <h6 class="dash-modal-heading">Supprimer validation tuteur</h6>
                            <div class="dash-modal-module">{{ module.title }}</div>
                            <div class="dash-modal-date">{{ action.mentorValidatedAt|date('d/m/Y') }}</div>
                            <div class="dash-modal-warning">
                                <p><strong>Attention :</strong> Suppression de la validation tuteur.</p>
                            </div>
                            <p class="dash-modal-confirm-text">Confirmer ?</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="dash-modal-btn-cancel" data-bs-dismiss="modal">Annuler</button>
                            <button type="button" class="dash-modal-btn-confirm" onclick="document.getElementById('form_mentor_mobile_{{ action.id|replace({'-': '_'}) }}').submit();">Confirmer</button>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    {% endfor %}
{% endfor %}
{% endblock %}
