{% extends 'base.html.twig' %}

{% block title %}Assignation automatique de modèles de carnet
{% endblock %}

{% block body %}
	<div
		class="container-fluid py-3 py-md-4">
		{# En-tête de page #}
		<div class="dashboard-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
			<div>
				<h1 class="text-dark" id="page-title">
                    <twig:ux:icon name="bi:book" class="me-2 me-md-3"/>
					Assignation automatique de modèles de carnet
				</h1>
				<p class="mb-3 mb-md-0 mt-2 text-muted">
					Attribuez des carnets aux utilisateurs de votre service en fonction de leur métier
				</p>
			</div>
			<div>
				<a href="{{ path('admin') }}" class="btn btn-outline-secondary rounded-pill shadow-sm" style="padding: 0.6rem 1.2rem;" aria-label="Retour au tableau de bord">
					<twig:ux:icon name="bi:arrow-left" class="me-2" />Tableau de bord
				</a>
			</div>
		</div>

		{# Bandeau d'information avec statistiques #}
		<div
			class="row g-3 mb-4">
			{# Carte Service #}
			<div class="col-12 col-md-4">
				<div class="card border-0 shadow-sm h-100" style="border-left: 4px solid var(--primary-color) !important;">
					<div class="card-body d-flex align-items-center">
						<div class="d-flex align-items-center w-100">
							<div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; min-width: 56px; flex-shrink: 0;">
								<twig:ux:icon name="bi:building" style="color: var(--primary-color); font-size: 1.5rem;"/>
							</div>
							<div class="ms-3">
								<p class="text-muted mb-1 small">Votre service</p>
								<h3 class="h5 mb-0 fw-bold">{{ app.user.service.name }}</h3>
							</div>
						</div>
					</div>
				</div>
			</div>

			{# Carte Total utilisateurs #}
			<div class="col-12 col-md-4">
				<div class="card border-0 shadow-sm h-100" style="border-left: 4px solid #0277bd !important;">
					<div class="card-body d-flex align-items-center">
						<div class="d-flex align-items-center w-100">
							<div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; min-width: 56px; flex-shrink: 0;">
								<twig:ux:icon name="bi:people" style="color: #0277bd; font-size: 1.5rem;"/>
							</div>
							<div class="ms-3">
								<p class="text-muted mb-1 small">Utilisateurs du service</p>
								<h3 class="h5 mb-0 fw-bold">{{ stats.total_users_in_service }}</h3>
							</div>
						</div>
					</div>
				</div>
			</div>

			{# Carte Utilisateurs éligibles #}
			<div class="col-12 col-md-4">
				<div class="card border-0 shadow-sm h-100" style="border-left: 4px solid {% if stats.eligible_users > 0 %}#2e7d32{% else %}#e65100{% endif %} !important;">
					<div class="card-body d-flex align-items-center">
						<div class="d-flex align-items-center w-100">
							<div class="rounded-circle {% if stats.eligible_users > 0 %}bg-success{% else %}bg-warning{% endif %} bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 56px; height: 56px; min-width: 56px; flex-shrink: 0;">
								<twig:ux:icon name="bi:person-check" style="color: {% if stats.eligible_users > 0 %}#2e7d32{% else %}#e65100{% endif %}; font-size: 1.5rem;"/>
							</div>
							<div class="ms-3">
								<p class="text-muted mb-1 small">Éligibles à l'assignation</p>
								<h3 class="h5 mb-0 fw-bold">{{ stats.eligible_users }}</h3>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		{# Bandeau informatif #}
		<div class="card border-0 shadow-sm mb-4" style="border-left: 4px solid #0277bd !important;">
			<div class="card-body p-4">
				<div class="d-flex align-items-start">
					<div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px; min-width: 48px; flex-shrink: 0;">
						<twig:ux:icon name="bi:info-circle" style="color: #0277bd; font-size: 1.25rem;"/>
					</div>
					<div class="flex-grow-1">
						<h3 class="h6 fw-bold mb-3 text-dark">Critères de filtrage</h3>
						<p class="text-muted mb-3" style="line-height: 1.6;">
							Cette page affiche uniquement les utilisateurs de votre service
							<span class="badge bg-info-subtle text-info-emphasis rounded-pill px-3 py-2 fw-semibold">
								{{ app.user.service.name }}
							</span>
							qui remplissent les critères suivants :
						</p>
						<div class="row g-3">
							<div class="col-12 col-md-4">
								<div class="d-flex align-items-start">
									<twig:ux:icon name="bi:check-circle-fill" class="text-success me-2 mt-1" style="font-size: 1rem; flex-shrink: 0;"/>
									<span class="text-muted small">Aucun carnet assigné</span>
								</div>
							</div>
							<div class="col-12 col-md-4">
								<div class="d-flex align-items-start">
									<twig:ux:icon name="bi:check-circle-fill" class="text-success me-2 mt-1" style="font-size: 1rem; flex-shrink: 0;"/>
									<span class="text-muted small">Au poste depuis moins d'un an</span>
								</div>
							</div>
							<div class="col-12 col-md-4">
								<div class="d-flex align-items-start">
									<twig:ux:icon name="bi:check-circle-fill" class="text-success me-2 mt-1" style="font-size: 1rem; flex-shrink: 0;"/>
									<span class="text-muted small">Métier avec modèle compatible</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		{# Contenu principal #}
		<div
			class="card border-0 shadow-sm" style="border-radius: 0.5rem;">
			{# En-tête avec compteur #}
			<div class="card-header bg-white border-bottom-0 py-4 px-4" style="border-radius: 0.5rem 0.5rem 0 0;">
				<div class="d-flex justify-content-between align-items-center">
					<div class="d-flex align-items-center">
						<div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
							<twig:ux:icon name="bi:person-workspace" style="color: var(--primary-color); font-size: 1.1rem;"/>
						</div>
						<div>
							<h2 class="h5 mb-0 fw-bold text-dark">Utilisateurs sans carnet</h2>
							<p class="text-muted small mb-0">Sélectionnez les utilisateurs à qui assigner un carnet</p>
						</div>
					</div>
					{% if users|length > 0 %}
						<span class="badge bg-primary-subtle text-primary-emphasis rounded-pill px-3 py-2 fs-6">
							{{ users|length }}
							utilisateur{{ users|length > 1 ? 's' : '' }}
						</span>
					{% endif %}
				</div>
			</div>

			{% if users|length > 0 %}
				{# Tableau desktop #}
				<div class="d-none d-lg-block">
					<div class="table-responsive">
						<table class="table table-hover align-middle mb-0">
							<thead class="bg-light border-top">
								<tr>
									<th scope="col" class="py-3 px-4 fw-semibold text-muted small text-uppercase border-0">Nom</th>
									<th scope="col" class="py-3 px-4 fw-semibold text-muted small text-uppercase border-0">Email</th>
									<th scope="col" class="py-3 px-4 fw-semibold text-muted small text-uppercase border-0">Métier</th>
									<th scope="col" class="py-3 px-4 fw-semibold text-muted small text-uppercase border-0">Service</th>
									<th scope="col" class="py-3 px-4 fw-semibold text-muted small text-uppercase border-0 text-end">Actions</th>
								</tr>
							</thead>
							<tbody>
								{% for user in users %}
									<tr style="transition: background-color 0.15s ease;">
										<td class="py-3 px-4 border-0">
											<div class="d-flex align-items-center">
												<div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; min-width: 36px;">
													<twig:ux:icon name="bi:person-fill" style="color: var(--primary-color); font-size: 0.9rem;"/>
												</div>
												<span class="ms-3 fw-semibold text-dark">{{ user.fullName }}</span>
											</div>
										</td>
										<td class="py-3 px-4 border-0">
											<span class="text-muted">{{ user.email }}</span>
										</td>
										<td class="py-3 px-4 border-0">
											{% if user.job %}
												<span class="badge bg-primary-subtle text-primary-emphasis rounded-pill px-3 py-2 fw-normal">
													{{ user.job.name }}
												</span>
											{% else %}
												<span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill px-3 py-2 fw-normal">
													Non défini
												</span>
											{% endif %}
										</td>
										<td class="py-3 px-4 border-0">
											{% if user.service %}
												<span class="badge bg-success-subtle text-success-emphasis rounded-pill px-3 py-2 fw-normal">
													{{ user.service.name }}
												</span>
											{% else %}
												<span class="badge bg-secondary-subtle text-secondary-emphasis rounded-pill px-3 py-2 fw-normal">
													Non défini
												</span>
											{% endif %}
										</td>
										<td class="py-3 px-4 border-0 text-end">
											<a href="{{ path('admin_user_assign_template', {'id': user.id}) }}" class="btn btn-sm btn-primary rounded-pill px-3 py-2" style="transition: all 0.2s ease;">
												<twig:ux:icon name="bi:plus-circle" class="me-1" style="font-size: 0.875rem;"/>
												Assigner
											</a>
										</td>
									</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
				</div>

				{# Cartes mobiles #}
				<div class="d-lg-none p-3 border-top">
					<div class="row g-3">
						{% for user in users %}
							<div class="col-12">
								<div class="card border shadow-sm" style="border-radius: 0.5rem;">
									<div class="card-body p-3">
										<div class="d-flex align-items-start mb-3">
											<div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 44px; height: 44px; min-width: 44px;">
												<twig:ux:icon name="bi:person-fill" style="color: var(--primary-color); font-size: 1.1rem;"/>
											</div>
											<div class="flex-grow-1">
												<h3 class="h6 fw-bold mb-1 text-dark">{{ user.fullName }}</h3>
												<p class="text-muted mb-0 small">{{ user.email }}</p>
											</div>
										</div>

										<div class="d-flex flex-wrap gap-2 mb-3">
											{% if user.job %}
												<span class="badge bg-primary-subtle text-primary-emphasis rounded-pill px-3 py-2 fw-normal">
													<twig:ux:icon name="bi:briefcase" class="me-1" style="font-size: 0.75rem;"/>
													{{ user.job.name }}
												</span>
											{% endif %}
											{% if user.service %}
												<span class="badge bg-success-subtle text-success-emphasis rounded-pill px-3 py-2 fw-normal">
													<twig:ux:icon name="bi:building" class="me-1" style="font-size: 0.75rem;"/>
													{{ user.service.name }}
												</span>
											{% endif %}
										</div>

										<div class="d-grid">
											<a href="{{ path('admin_user_assign_template', {'id': user.id}) }}" class="btn btn-primary rounded-pill">
												<twig:ux:icon name="bi:plus-circle" class="me-2" style="font-size: 1rem;"/>
												Assigner un carnet
											</a>
										</div>
									</div>
								</div>
							</div>
						{% endfor %}
					</div>
				</div>

				{# Section Assignation automatique - INTÉGRÉE DANS LA MÊME CARTE #}
				<div class="border-top bg-light p-4" style="border-radius: 0 0 0.5rem 0.5rem;">
					<form
						method="post" action="{{ path('admin_batch_assign_templates') }}">
						{# Bandeau d'information #}
						<div class="alert alert-info border-0 d-flex align-items-start mb-4" style="background-color: rgba(13, 110, 253, 0.05); border-radius: 0.5rem;">
							<div class="rounded-circle bg-info bg-opacity-10 d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; min-width: 40px; flex-shrink: 0;">
								<twig:ux:icon name="bi:lightning-charge-fill" style="color: #0277bd; font-size: 1.1rem;"/>
							</div>
							<div class="flex-grow-1">
								<h3 class="h6 fw-bold mb-2 text-dark">Assignation automatique en masse</h3>
								<p class="mb-0 text-muted small" style="line-height: 1.6;">
									Cette action attribuera automatiquement un carnet modèle par défaut
									{% if users|length == 1 %}
										à
										<strong class="text-dark">l'utilisateur listé</strong>
										ci-dessus.
									{% else %}
										aux
										<strong class="text-dark">{{ users|length }}
											utilisateurs listés</strong>
										ci-dessus.
									{% endif %}
									Le carnet sera adapté en fonction
									{{ users|length == 1 ? 'de son' : 'de leur' }}
									métier.
								</p>
							</div>
						</div>

						{# Boutons d'action #}
						<div class="d-flex flex-column flex-md-row justify-content-between gap-3">
							<a href="{{ path('admin') }}" class="btn btn-outline-secondary rounded-pill px-4 py-2 d-flex align-items-center justify-content-center" style="transition: all 0.2s ease;">
								<twig:ux:icon name="bi:arrow-left" class="me-2" style="font-size: 1rem;"/>
								Retour au tableau de bord
							</a>
							<button type="submit" class="btn btn-primary rounded-pill px-4 py-2 d-flex align-items-center justify-content-center" style="transition: all 0.2s ease;" aria-label="Assigner automatiquement un carnet à {{ users|length }} utilisateur(s)">
								<twig:ux:icon name="bi:magic" class="me-2" style="font-size: 1rem;"/>
								Assigner automatiquement ({{ users|length }})
							</button>
						</div>
					</form>
				</div>

			{% else %}
				{# État vide - SIMPLIFIÉ #}
				<div class="card-body p-5 text-center">
					<div class="mb-4">
						<div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
							<twig:ux:icon name="bi:inbox" style="color: #adb5bd; font-size: 2.5rem;"/>
						</div>
					</div>

					<h3 class="h4 mb-3 fw-bold text-dark">Aucun utilisateur éligible</h3>
					<p class="text-muted mb-4 mx-auto" style="max-width: 500px; line-height: 1.6;">
						Tous les utilisateurs de votre service
						<strong class="text-dark">{{ app.user.service.name }}</strong>
						ont déjà un carnet assigné, ou ne remplissent pas les critères d'éligibilité.
					</p>

					{# Critères d'éligibilité #}
					<div class="card border-0 bg-light mb-4 mx-auto" style="max-width: 600px; border-radius: 0.5rem;">
						<div class="card-body p-4">
							<h4 class="h6 fw-bold mb-3 text-dark d-flex align-items-center justify-content-center">
								<twig:ux:icon name="bi:lightbulb-fill" class="me-2 text-warning" style="font-size: 1.25rem;"/>
								Critères d'éligibilité
							</h4>
							<div class="row g-2 text-start">
								<div class="col-12 col-md-6">
									<div class="d-flex align-items-start">
										<twig:ux:icon name="bi:check-circle-fill" class="text-success me-2 mt-1 flex-shrink-0" style="font-size: 0.9rem;"/>
										<span class="text-muted small">Aucun carnet assigné</span>
									</div>
								</div>
								<div class="col-12 col-md-6">
									<div class="d-flex align-items-start">
										<twig:ux:icon name="bi:check-circle-fill" class="text-success me-2 mt-1 flex-shrink-0" style="font-size: 0.9rem;"/>
										<span class="text-muted small">Embauché depuis moins d'un an</span>
									</div>
								</div>
								<div class="col-12 col-md-6">
									<div class="d-flex align-items-start">
										<twig:ux:icon name="bi:check-circle-fill" class="text-success me-2 mt-1 flex-shrink-0" style="font-size: 0.9rem;"/>
										<span class="text-muted small">Métier défini</span>
									</div>
								</div>
								<div class="col-12 col-md-6">
									<div class="d-flex align-items-start">
										<twig:ux:icon name="bi:check-circle-fill" class="text-success me-2 mt-1 flex-shrink-0" style="font-size: 0.9rem;"/>
										<span class="text-muted small">Modèle compatible existant</span>
									</div>
								</div>
							</div>
						</div>
					</div>

					{# Statistiques #}
					<p class="text-muted small mb-4">
						<twig:ux:icon name="bi:graph-up" class="me-1"/>
						<strong class="text-dark">{{ stats.users_without_logbook }}</strong>
						utilisateur(s) sans carnet sur
						<strong class="text-dark">{{ stats.total_users_in_service }}</strong>
						dans votre service
					</p>

					<a href="{{ path('admin') }}" class="btn btn-outline-secondary rounded-pill px-4 py-2" style="transition: all 0.2s ease;">
						<twig:ux:icon name="bi:arrow-left" class="me-2" style="font-size: 1rem;"/>
						Retour au tableau de bord
					</a>
				</div>
			{% endif %}
		</div>

	</div>
</div></div>{% endblock %}
